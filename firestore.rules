rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Owner (#5) and admin (#11) access aren't built yet — each issue adds its
    // own allow clause here when it lands (see ARCHITECTURE.md §13).
    match /requests/{requestId} {
      allow read, write: if request.auth != null
        && request.auth.token.role == 'advisor'
        && resource.data.assignedAdvisorUid == request.auth.uid;
    }

    // advisors' personal follow-up tasks — requestUid is an optional link
    // back to a client, not an access-control field (see ARCHITECTURE.md §13).
    match /tasks/{taskId} {
      allow create: if request.auth != null
        && request.auth.token.role == 'advisor'
        && request.resource.data.advisorUid == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && request.auth.token.role == 'advisor'
        && resource.data.advisorUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}