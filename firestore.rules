rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Owner (#5) and admin (#11) access aren't built yet — each issue adds its
    // own allow clause here when it lands (see ARCHITECTURE.md §13).
    match /requests/{requestId} {
      allow read, write: if request.auth != null
        && request.auth.token.role == 'advisor'
        && resource.data.assignedAdvisorUid == request.auth.uid;
    }

    // requests/{uid}/messages — consumer↔advisor thread (issue #10, consumer
    // side; advisor side is a UI placeholder for now, see ARCHITECTURE.md §13).
    // sender is validated against the caller's identity so neither side can
    // post a message impersonating the other.
    match /requests/{requestId}/messages/{messageId} {
      allow read: if request.auth != null
        && (request.auth.uid == requestId
            || (request.auth.token.role == 'advisor'
                && get(/databases/$(database)/documents/requests/$(requestId)).data.assignedAdvisorUid == request.auth.uid));
      allow create: if request.auth != null
        && ((request.auth.uid == requestId && request.resource.data.sender == 'consumer')
            || (request.auth.token.role == 'advisor'
                && get(/databases/$(database)/documents/requests/$(requestId)).data.assignedAdvisorUid == request.auth.uid
                && request.resource.data.sender == 'advisor'));
    }

    // advisors' personal follow-up tasks — requestUid is an optional link
    // back to a client, not an access-control field (see ARCHITECTURE.md §13).
    match /tasks/{taskId} {
      allow create: if request.auth != null
        && request.auth.token.role == 'advisor'
        && request.resource.data.advisorUid == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && request.auth.token.role == 'advisor'
        && resource.data.advisorUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}