rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /requests/{requestId} {
      // Admin (#11): full access to every request regardless of assignment.
      allow read, write: if request.auth != null
        && request.auth.token.role == 'admin';

      // Newly-registered user creates their initial document during signup
      // BEFORE claimConsumerRole sets the role claim (migrateDraftOnSignup runs
      // first — see SignUpPage.tsx completeSignup). `create` only applies to
      // brand-new documents so this cannot be abused to overwrite existing records.
      allow create: if request.auth != null
        && request.auth.uid == requestId;

      // Consumer can read their own request even before the role claim is
      // refreshed into the token (window between signup and first getIdToken).
      // UID ownership is sufficient for reads — the document only exists for
      // the user who created it.
      allow read: if request.auth != null
        && request.auth.uid == requestId;

      // Updates require the consumer role to be confirmed in the token.
      allow update: if request.auth != null
        && request.auth.uid == requestId
        && request.auth.token.role == 'consumer';

      // Advisor can read/write requests assigned to them (issue #8)
      allow read, write: if request.auth != null
        && request.auth.token.role == 'advisor'
        && resource.data.assignedAdvisorUid == request.auth.uid;
    }

    // requests/{uid}/events — signature event written by the consumer
    // when they sign the disclosure form (usePersonalArea signCredentials).
    match /requests/{requestId}/events/{eventId} {
      allow create, read: if request.auth != null
        && request.auth.uid == requestId
        && request.auth.token.role == 'consumer';
      allow read: if request.auth != null
        && (request.auth.token.role == 'admin'
            || (request.auth.token.role == 'advisor'
                && get(/databases/$(database)/documents/requests/$(requestId)).data.assignedAdvisorUid == request.auth.uid));
    }

    // requests/{uid}/messages — consumer↔advisor thread (issue #10).
    match /requests/{requestId}/messages/{messageId} {
      allow read: if request.auth != null
        && (request.auth.uid == requestId
            || (request.auth.token.role == 'advisor'
                && get(/databases/$(database)/documents/requests/$(requestId)).data.assignedAdvisorUid == request.auth.uid));
      allow create: if request.auth != null
        && ((request.auth.uid == requestId && request.resource.data.sender == 'consumer')
            || (request.auth.token.role == 'advisor'
                && get(/databases/$(database)/documents/requests/$(requestId)).data.assignedAdvisorUid == request.auth.uid
                && request.resource.data.sender == 'advisor'));
    }

    // Managed config (generalRates, riskRules, clockTemplates, monthlyIndices).
    // Written and read by admin (#11); read by the calc-engine Cloud Function.
    match /config/{configKey} {
      allow read, write: if request.auth != null
        && request.auth.token.role == 'admin';
    }

    // advisors' personal follow-up tasks — requestUid is an optional link
    // back to a client, not an access-control field (see ARCHITECTURE.md §13).
    match /tasks/{taskId} {
      allow create: if request.auth != null
        && request.auth.token.role == 'advisor'
        && request.resource.data.advisorUid == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && request.auth.token.role == 'advisor'
        && resource.data.advisorUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}